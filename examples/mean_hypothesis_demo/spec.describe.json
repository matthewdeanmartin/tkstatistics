{
  "spec_version": 1,
  "analysis": "ttest_1samp",
  "dataset": "mean_test_demo",
  "inputs": {
    "data": "score"
  },
  "options": {
    "null_mean": 10,
    "alternative": "two-sided",
    "conf_level": 0.95
  },
  "seed": 12345,
  "mode": "confirmatory",
  "plan_id": "mean-hypothesis-demo",
  "app_version": "0.1.0",
  "hypothesis": {
    "parameter": "mean(score)",
    "null": "mean = 10",
    "alternative": "mean != 10",
    "test": "one-sample student t"
  }
}
